{
  "type": "module",
  "license": "Apache-2.0",
  "name": "@sovereignbase/peer2peer",
  "version": "1.0.0",
  "description": "Simple WebRTC wrapper for peer to peer connection setup in browsers.",
  "keywords": [
    "peer-to-peer",
    "p2p",
    "webrtc",
    "rtcdatachannel",
    "signaling",
    "stun",
    "turn",
    "browser",
    "typescript",
    "sovereignbase"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "format": "prettier . --write",
    "build": "tsup && typedoc && node in-browser-testing-build.js",
    "test": "npm run build && node test/run-coverage.mjs && node test/e2e/run.mjs",
    "bench": "npm run build && node benchmark/bench.js",
    "prepare": "husky",
    "prepublishOnly": "npm run test && npm run bench"
  },
  "c8": {
    "all": true,
    "include": [
      "dist/**/*.js"
    ],
    "exclude": [
      "dist/index.browser.js",
      "dist/**/*.d.ts",
      "test/**",
      "benchmark/**",
      "playwright.config.ts"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "@sovereignbase/convergent-replicated-list": "^1.0.8",
    "@sovereignbase/offline-kv-store": "^1.0.2",
    "@sovereignbase/qr": "^1.2.0",
    "@types/node": "^25.6.0",
    "c8": "^11.0.0",
    "edge-runtime": "^4.0.1",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "wrangler": "^4.84.1",
    "ws": "^8.20.0"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sovereignbase/peer2peer.git"
  },
  "bugs": {
    "url": "https://github.com/sovereignbase/peer2peer/issues"
  },
  "homepage": "https://sovereignbase.dev/peer2peer"
}
